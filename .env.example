# Coordinator
DATABASE_URL=postgres://foreman:foreman@localhost:5432/foreman?sslmode=disable
REDIS_URL=redis://localhost:6379
PORT=8080
COORDINATOR_SECRET=dev-secret-change-in-prod
MAX_PARALLEL_JOBS_PER_WORKER=4

# MinIO artifact storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foreman-artifacts
MINIO_USE_SSL=false

# Worker
COORDINATOR_URL=http://localhost:8080
WORKER_CPU_CORES=2
WORKER_MEMORY_MB=1024
WORKER_MAX_PARALLEL_JOBS=4
